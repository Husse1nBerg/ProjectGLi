# Copy to server/.env and fill in. server/.env is gitignored — never commit it.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
PORT=3001

# Optional — enables real vehicle photos via Google Custom Search (image search).
# Leave blank to fall back to the imagin render. Free tier: 100 searches/day.
#   GOOGLE_API_KEY: console.cloud.google.com → enable "Custom Search API" → create key
#   GOOGLE_CSE_ID:  programmablesearchengine.google.com → create engine (search whole web, Image search ON)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
